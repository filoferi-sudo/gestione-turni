# === Variabili d'ambiente del sito marketing Planivo ===
# Copia in `.env` e valorizza. MAI committare `.env` con valori reali.
# Solo le variabili con prefisso PUBLIC_ sono esposte al browser (regola Astro).

# [OBBLIGATORIA] Base URL del backend (senza slash finale, senza /api).
# Il LeadForm invia a ${PUBLIC_API_URL}/api/public/leads.
# Es. https://turni-app-backend.vercel.app
PUBLIC_API_URL=

# [FACOLTATIVA] ID container Google Tag Manager (formato GTM-XXXXXXX).
# Se ASSENTE: nessun tracking caricato e nessun banner cookie (nessun cookie non tecnico).
PUBLIC_GTM_ID=

# [FACOLTATIVA] Link evento Calendly/Cal.com per l'embed nella pagina /grazie.
# Se assente: la pagina /grazie non mostra l'embed di prenotazione self-service.
PUBLIC_CALENDLY_URL=
