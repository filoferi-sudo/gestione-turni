---
import Base from '../layouts/Base.astro';
import LeadForm from '../components/LeadForm.astro';
import FaqList from '../components/FaqList.astro';
import CtaSection from '../components/CtaSection.astro';
import Icon from '../components/Icon.astro';
import { pricing } from '../data/pricing.js';

// Nessuna cifra pubblica: prezzo a preventivo su misura. Il modello (per sede, non per dipendente)
// resta la leva di valore. Un solo modello oggi; piani multipli sono nella roadmap abbonamenti.
---

<Base
  title="Prezzi di Planivo: un preventivo su misura, gratuito"
  description="Ogni struttura è diversa: Planivo ti fa un preventivo gratuito su misura. Un prezzo per sede, non per dipendente — prevedibile anche con lo staff stagionale."
>
  <section class="section page-hero text-center">
    <div class="container price-head">
      <p class="eyebrow">Prezzi</p>
      <h1>Un preventivo su misura, gratuito.</h1>
      <p class="lead">
        Ogni struttura è diversa: numero di sedi, aree, modo di lavorare. Per questo non trovi un
        listino rigido — ti facciamo un <strong>preventivo gratuito e senza impegno</strong>, sulla
        tua situazione reale. Il principio resta uno: <strong>si paga per sede, non per dipendente</strong>,
        così è prevedibile anche con gli stagionali.
      </p>
    </div>
  </section>

  <section class="section-top">
    <div class="container price-layout">
      <!-- Cosa è incluso + pilota -->
      <div class="price-side">
        <div class="card price-inc">
          <p class="price-inc__title">Tutto incluso, senza costi nascosti:</p>
          <ul class="price-inc__list">
            {pricing.included.map((i) => (
              <li><Icon name="check" size={18} /> <span>{i}</span></li>
            ))}
          </ul>
        </div>
        <aside class="price-pilot">
          <span class="price-pilot__badge"><Icon name="spark" size={18} /> {pricing.pilot.title}</span>
          <p>{pricing.pilot.text}</p>
        </aside>
      </div>

      <!-- Form preventivo -->
      <div class="card price-form">
        <h2>Richiedi il tuo preventivo</h2>
        <p class="price-form__sub">Raccontaci la tua struttura in 30 secondi: ti ricontattiamo con una proposta su misura, entro 24 ore.</p>
        <LeadForm source="preventivo" submitLabel="Richiedi il preventivo gratuito" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container price-faq">
      <div class="section__head">
        <p class="eyebrow">Domande sul prezzo</p>
        <h2>Prima che tu lo chieda.</h2>
      </div>
      <FaqList items={pricing.faq} />
    </div>
  </section>

  <CtaSection
    title="Non sei sicuro? Parti dal pilota gratuito."
    text="Un mese per capire se Planivo fa per te, configurazione inclusa. Poi decidi."
    cta="Prenota una demo"
  />
</Base>

<style>
  .page-hero h1 { margin: 0.75rem 0 1rem; }
  .price-head { max-width: 64ch; margin-inline: auto; }

  .section-top { padding-bottom: var(--space-section); }
  .price-layout {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    align-items: start;
  }
  @media (min-width: 880px) { .price-layout { grid-template-columns: 0.9fr 1.1fr; } }

  .price-side { display: flex; flex-direction: column; gap: 1.25rem; }
  .price-inc__title { font-weight: 600; color: var(--c-ink); margin-bottom: 0.75rem; }
  .price-inc__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .price-inc__list li { display: flex; align-items: flex-start; gap: 0.6rem; color: var(--c-body); }
  .price-inc__list svg { color: var(--c-primary); flex: none; margin-top: 3px; }

  .price-pilot {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: clamp(1.25rem, 3vw, 1.5rem);
  }
  .price-pilot__badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-display); font-weight: 700; color: var(--c-primary-dark);
    margin-bottom: 0.5rem;
  }
  .price-pilot > p { color: var(--c-body); }

  .price-form { border: 2px solid var(--c-primary); }
  .price-form h2 { font-size: 1.4rem; }
  .price-form__sub { color: var(--c-muted); margin-bottom: 1.25rem; }

  .price-faq { max-width: 800px; }
</style>
