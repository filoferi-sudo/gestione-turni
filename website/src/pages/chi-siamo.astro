---
import Base from '../layouts/Base.astro';
import CtaSection from '../components/CtaSection.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site.js';

const values = [
  { icon: 'spark', title: 'Semplicità prima di tutto', text: 'Se serve un corso per usarlo, abbiamo sbagliato noi. Planivo si impara in cinque minuti.' },
  { icon: 'users', title: 'Nato sul campo', text: 'Non a tavolino: Planivo nasce dall’esperienza diretta dei turni, dove i problemi si vedono davvero.' },
  { icon: 'check-shield', title: 'Sviluppato in Italia', text: 'Software italiano, supporto in italiano, dati su server europei. Ci trovi quando ti servono risposte.' },
];
---

<Base
  title="Chi siamo"
  description="Planivo nasce dall’esperienza diretta dei turni — a bordo vasca — dove i buchi di copertura sono un problema vero. La storia dietro Planivo."
>
  <section class="section page-hero">
    <div class="container chisiamo">
      <p class="eyebrow">Chi siamo</p>
      <h1>Nato a bordo vasca, non in un ufficio.</h1>

      <div class="chisiamo__story">
        <p class="lead">
          Planivo non nasce in un ufficio, ma in piscina. Ho 18 anni, ho studiato all’istituto tecnico
          economico e da qualche anno lavoro come <strong>nuotatore e bagnino</strong>.
        </p>
        <p>
          A bordo vasca ho visto con i miei occhi come funziona — male — la gestione dei turni: fogli
          Excel che nessuno aggiorna, cambi decisi al volo su WhatsApp, e la sera in cui manca un
          bagnino che diventa un problema serio, perché senza non si può nemmeno aprire. Mi sono
          chiesto perché una cosa così importante venisse gestita in modo così fragile.
        </p>
        <p>
          Così, unendo quello che studiavo di economia e organizzazione all’esperienza diretta dei
          turni, ho iniziato a costruire <strong>Planivo</strong>: uno strumento semplice che fa una
          cosa e la fa bene — coprire i turni scoperti con le persone giuste, senza far impazzire
          nessuno.
        </p>
        <p>
          Oggi Planivo non serve solo le piscine: ristoranti, bar e palestre hanno lo stesso identico
          problema. Ma l’idea di fondo è sempre quella di quel bordo vasca: i turni sono una cosa
          seria e meritano uno strumento serio, alla portata di tutti.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--paper">
    <div class="container">
      <div class="section__head">
        <p class="eyebrow">In cosa crediamo</p>
        <h2>Tre valori, zero fronzoli.</h2>
      </div>
      <div class="grid grid--3">
        {
          values.map((v) => (
            <article class="card">
              <span class="chisiamo__vic" aria-hidden="true"><Icon name={v.icon} size={22} /></span>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
            </article>
          ))
        }
      </div>
      <p class="chisiamo__where trust-flag">🇮🇹 Software italiano, sviluppato in {site.region}.</p>
    </div>
  </section>

  <CtaSection title="Parliamone." text="Raccontaci la tua struttura: in 15 minuti ti mostriamo se Planivo fa al caso tuo." cta="Prenota una demo" />
</Base>

<style>
  .chisiamo { max-width: 68ch; }
  .chisiamo h1 { margin: 0.75rem 0 1.5rem; max-width: 20ch; }
  .chisiamo__story { max-width: 64ch; }
  .chisiamo__story p + p { margin-top: 1rem; }
  .chisiamo__story .lead { margin-bottom: 1rem; }
  .chisiamo__vic {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: 12px;
    background: var(--c-primary-tint); color: var(--c-primary-dark); margin-bottom: 0.5rem;
  }
  .chisiamo__where { margin-top: 2rem; color: var(--c-body); }
</style>
