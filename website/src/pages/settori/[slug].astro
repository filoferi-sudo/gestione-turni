---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Screenshot from '../../components/Screenshot.astro';
import FaqList from '../../components/FaqList.astro';
import CtaSection from '../../components/CtaSection.astro';
import Icon from '../../components/Icon.astro';
import { breadcrumb, faqPage } from '../../lib/jsonld.js';

export async function getStaticPaths() {
  const sectors = await getCollection('settori');
  return sectors.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const data = entry.data;
const { Content } = await render(entry);

const demoLabels = {
  ristoranti: 'il tuo ristorante',
  bar: 'il tuo bar',
  piscine: 'la tua piscina',
  palestre: 'la tua palestra',
};
const demoLabel = demoLabels[entry.id] || 'la tua struttura';
const demoHref = `/demo?settore=${entry.id}`;

const jsonLd = [
  breadcrumb([
    { name: 'Settori', path: '/settori' },
    { name: data.title, path: `/settori/${entry.id}` },
  ]),
  ...(data.faq.length ? [faqPage(data.faq)] : []),
];
---

<Base title={data.seoTitle} description={data.seoDescription} jsonLd={jsonLd}>
  <!-- Breadcrumb -->
  <nav class="container breadcrumb" aria-label="Percorso">
    <a href="/settori">Settori</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">{data.title}</span>
  </nav>

  <!-- Hero di settore -->
  <section class="section sector-hero">
    <div class="container sector-hero__grid">
      <div>
        <p class="eyebrow">{data.title}</p>
        <h1>{data.hook}</h1>
        <div class="sector-hero__intro"><Content /></div>
        <a href={demoHref} class="btn btn-primary btn--lg" data-track="cta-demo">Richiedi una demo per {demoLabel}</a>
      </div>
      <div class="sector-hero__icon" aria-hidden="true"><Icon name={data.icon} size={64} /></div>
    </div>
  </section>

  <!-- Ti riconosci? (pains, accento ambra) -->
  <section class="section section--paper">
    <div class="container">
      <div class="section__head">
        <p class="eyebrow">Ti riconosci?</p>
        <h2>I problemi di ogni settimana.</h2>
      </div>
      <div class="grid grid--3">
        {
          data.pains.map((p) => (
            <article class="card pain-card">
              <span class="pain-card__icon" aria-hidden="true"><Icon name="alert" size={20} /></span>
              <p>{p}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Come lo risolve Planivo (solutions, accento verde) + screenshot -->
  <section class="section">
    <div class="container sol-grid">
      <div>
        <div class="section__head">
          <p class="eyebrow">Come lo risolve Planivo</p>
          <h2>Dal problema alla soluzione.</h2>
        </div>
        <ul class="sol-list">
          {
            data.solutions.map((s) => (
              <li>
                <span class="sol-list__ic" aria-hidden="true"><Icon name="check-circle" size={22} /></span>
                <div>
                  <h3>{s.title}</h3>
                  <p>{s.text}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="sol-visual">
        <Screenshot mock={data.screenshotMock} alt={`Planivo per ${data.title.toLowerCase()}`} tag="Anteprima" />
        {/* TODO caso pilota: mini-caso-studio di settore quando disponibile. */}
        <p class="sol-casestudy">
          <Icon name="spark" size={16} /> Le prime strutture del settore partono con un <strong>pilota gratuito</strong>.
        </p>
      </div>
    </div>
  </section>

  {
    data.faq.length > 0 && (
      <section class="section section--paper">
        <div class="container sector-faq">
          <div class="section__head">
            <p class="eyebrow">Domande frequenti</p>
            <h2>Sul tuo settore.</h2>
          </div>
          <FaqList items={data.faq} />
        </div>
      </section>
    )
  }

  <CtaSection
    title={`Vediamolo su ${demoLabel}.`}
    text="15 minuti, sui tuoi turni reali. Nessun impegno."
    cta={`Richiedi una demo per ${demoLabel}`}
    href={demoHref}
  />
</Base>

<style>
  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    padding-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--c-muted);
  }
  .breadcrumb a { color: var(--c-primary-dark); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .sector-hero { padding-top: 1.5rem; }
  .sector-hero__grid { display: grid; gap: 2rem; align-items: center; }
  @media (min-width: 860px) { .sector-hero__grid { grid-template-columns: 1fr auto; } }
  .sector-hero h1 { margin: 0.75rem 0 1rem; max-width: 20ch; }
  .sector-hero__intro { color: var(--c-body); margin-bottom: 1.75rem; max-width: 60ch; }
  .sector-hero__intro :global(p) { font-size: 1.075rem; }
  .sector-hero__icon {
    width: 120px; height: 120px; border-radius: var(--radius-lg);
    background: var(--c-primary-tint); color: var(--c-primary-dark);
    display: none; align-items: center; justify-content: center;
  }
  @media (min-width: 860px) { .sector-hero__icon { display: flex; } }

  .pain-card { border-left: 3px solid var(--c-gap); }
  .pain-card__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--c-gap-tint); color: var(--c-gap-ink); margin-bottom: 0.75rem;
  }
  .pain-card p { color: var(--c-body); }

  .sol-grid { display: grid; gap: clamp(1.75rem, 4vw, 3rem); align-items: start; }
  @media (min-width: 900px) { .sol-grid { grid-template-columns: 1fr 1fr; } }
  .sol-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.25rem; }
  .sol-list li { display: flex; gap: 0.85rem; align-items: flex-start; }
  .sol-list__ic { color: var(--c-primary); flex: none; margin-top: 2px; }
  .sol-list h3 { margin-bottom: 0.25rem; }
  .sol-list p { color: var(--c-body); }
  .sol-visual { position: sticky; top: 84px; }
  .sol-casestudy {
    display: flex; align-items: center; gap: 0.4rem;
    margin-top: 1rem; font-size: 0.92rem; color: var(--c-muted);
  }
  .sol-casestudy svg { color: var(--c-gap); flex: none; }
  .sector-faq { max-width: 820px; }
</style>
