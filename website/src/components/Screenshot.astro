---
// Mostra uno screenshot del gestionale dentro una cornice "browser". Se `src` punta a un file reale
// in /public/screenshots/ lo usa; altrimenti rende un MOCK on-brand (placeholder chiaramente
// illustrativo). Quando i PNG reali sono pronti (§12), basta passare `src` e sparisce il mock.
//
// Props: src?, alt, caption?, mock ('calendario'|'sostituzione'|'copertura'), tag?
const { src, alt = '', caption, mock = 'calendario', tag } = Astro.props;
const days = ['Lun', 'Mar', 'Mer', 'Gio', 'Ven', 'Sab', 'Dom'];
---
<figure class="shot">
  <div class="shot__frame">
    <div class="shot__bar" aria-hidden="true">
      <span class="shot__dot"></span><span class="shot__dot"></span><span class="shot__dot"></span>
      <span class="shot__url">planivo.it/app</span>
    </div>

    {
      src ? (
        <img class="shot__img" src={src} alt={alt} loading="lazy" decoding="async" />
      ) : (
        <div class="shot__mock" role="img" aria-label={alt}>
          {tag && <span class="shot__tag">{tag}</span>}

          {mock === 'calendario' && (
            <div class="mock mock--cal">
              <div class="mock__tabs"><span class="mock__tab is-active">Bagnini</span><span class="mock__tab">Reception</span><span class="mock__tab">Bar</span></div>
              <div class="mock__cal">
                <div class="mock__corner" />
                {days.map((d) => <div class="mock__day">{d}</div>)}
                {['08–14', '14–20', '20–24'].map((band, r) => (
                  <>
                    <div class="mock__band">{band}</div>
                    {days.map((_, c) => {
                      const gap = r === 2 && c === 4;
                      const filled = (r + c) % 3 !== 0;
                      return (
                        <div class="mock__slot">
                          {gap ? <span class="mock__blk mock__blk--gap">scoperto</span> : filled ? <span class="mock__blk">•</span> : null}
                        </div>
                      );
                    })}
                  </>
                ))}
              </div>
            </div>
          )}

          {mock === 'sostituzione' && (
            <div class="mock mock--sub">
              <p class="mock__h">Turno scoperto · Ven 20–24 · Bagnini</p>
              <p class="mock__sub">Candidati idonei, in ordine di compatibilità</p>
              {[
                { n: 'Giulia R.', s: '98', why: 'Disponibile · sotto le ore settimanali' },
                { n: 'Luca M.', s: '81', why: 'Disponibile · +2 turni questa settimana' },
                { n: 'Sara P.', s: '64', why: 'Nessuna disponibilità dichiarata' },
              ].map((c, i) => (
                <div class="mock__cand">
                  <span class="mock__avatar">{c.n.charAt(0)}</span>
                  <span class="mock__cand-main"><b>{c.n}</b><em>{c.why}</em></span>
                  <span class:list={['mock__score', { 'is-top': i === 0 }]}>{c.s}</span>
                </div>
              ))}
            </div>
          )}

          {mock === 'copertura' && (
            <div class="mock mock--cov">
              <p class="mock__h">Copertura di oggi · per fascia</p>
              {[
                { t: '08–12', need: 3, have: 3 },
                { t: '12–16', need: 4, have: 4 },
                { t: '16–20', need: 4, have: 3 },
                { t: '20–24', need: 2, have: 2 },
              ].map((f) => (
                <div class="mock__cov-row">
                  <span class="mock__cov-t num">{f.t}</span>
                  <span class="mock__bars">
                    {Array.from({ length: f.need }).map((_, i) => (
                      <span class:list={['mock__cell', i < f.have ? 'is-ok' : 'is-gap']} />
                    ))}
                  </span>
                  <span class:list={['chip', f.have >= f.need ? 'chip--coperto' : 'chip--scoperto']}>
                    {f.have}/{f.need}
                  </span>
                </div>
              ))}
            </div>
          )}
        </div>
      )
    }
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .shot { margin: 0; }
  .shot__frame {
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lift);
    background: var(--c-bg);
  }
  .shot__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.6rem 0.9rem;
    background: var(--c-surface);
    border-bottom: 1px solid var(--c-border);
  }
  .shot__dot { width: 10px; height: 10px; border-radius: 50%; background: var(--c-border); }
  .shot__url {
    margin-left: 0.6rem;
    font-family: var(--font-num);
    font-size: 0.72rem;
    color: var(--c-muted);
    background: var(--c-bg);
    padding: 0.15rem 0.6rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--c-border);
  }
  .shot__img { width: 100%; height: auto; display: block; }
  .shot__mock { padding: clamp(0.9rem, 3vw, 1.4rem); position: relative; background: var(--c-paper); }
  .shot__tag {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--c-muted);
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-pill);
    padding: 0.1rem 0.5rem;
  }
  figcaption { margin-top: 0.75rem; font-size: 0.9rem; color: var(--c-muted); text-align: center; }

  /* ---- Mock calendario ---- */
  .mock__tabs { display: flex; gap: 0.4rem; margin-bottom: 0.75rem; }
  .mock__tab {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-pill);
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    color: var(--c-muted);
  }
  .mock__tab.is-active { background: var(--c-primary); color: #fff; border-color: var(--c-primary); }
  .mock__cal { display: grid; grid-template-columns: auto repeat(7, 1fr); gap: 4px; }
  .mock__corner { }
  .mock__day { text-align: center; font-size: 0.62rem; font-weight: 600; color: var(--c-muted); font-family: var(--font-num); }
  .mock__band { font-size: 0.6rem; color: var(--c-muted); align-self: center; white-space: nowrap; font-family: var(--font-num); }
  .mock__slot {
    aspect-ratio: 1;
    min-height: 22px;
    border-radius: 5px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    display: flex; align-items: center; justify-content: center;
  }
  .mock__blk {
    width: 100%; height: 100%;
    border-radius: 5px;
    background: var(--c-primary-tint);
    color: var(--c-primary);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem;
  }
  .mock__blk--gap {
    background: var(--c-gap-tint);
    color: var(--c-gap-ink);
    font-size: 0.52rem;
    font-weight: 600;
  }

  /* ---- Mock sostituzione ---- */
  .mock__h { font-family: var(--font-display); font-weight: 700; color: var(--c-ink); font-size: 0.95rem; }
  .mock__sub { font-size: 0.78rem; color: var(--c-muted); margin-bottom: 0.75rem; }
  .mock__cand {
    display: flex; align-items: center; gap: 0.6rem;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    padding: 0.55rem 0.7rem;
    margin-bottom: 0.5rem;
  }
  .mock__avatar {
    width: 30px; height: 30px; flex: none;
    border-radius: 50%;
    background: var(--c-surface);
    color: var(--c-primary-dark);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.85rem;
  }
  .mock__cand-main { display: flex; flex-direction: column; flex: 1; line-height: 1.25; }
  .mock__cand-main b { font-size: 0.85rem; color: var(--c-ink); }
  .mock__cand-main em { font-style: normal; font-size: 0.72rem; color: var(--c-muted); }
  .mock__score {
    font-family: var(--font-num); font-weight: 700; font-size: 0.9rem;
    color: var(--c-muted);
    background: var(--c-surface);
    border-radius: 8px;
    padding: 0.15rem 0.5rem;
  }
  .mock__score.is-top { background: var(--c-primary-tint); color: var(--c-primary-dark); }

  /* ---- Mock copertura ---- */
  .mock--cov .mock__h { margin-bottom: 0.75rem; }
  .mock__cov-row { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
  .mock__cov-t { font-size: 0.75rem; color: var(--c-muted); width: 3rem; flex: none; }
  .mock__bars { display: flex; gap: 3px; flex: 1; }
  .mock__cell { height: 16px; flex: 1; border-radius: 3px; }
  .mock__cell.is-ok { background: var(--c-primary); }
  .mock__cell.is-gap { background: var(--c-gap); opacity: 0.5; }
  .mock--cov .chip { flex: none; }
</style>
