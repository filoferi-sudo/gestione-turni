---
// Wordmark Planivo: mark (cella-turno "coperta") + testo in font display verde.
// `variant="footer"` usa il testo chiaro per fondi scuri.
const { variant = 'default' } = Astro.props;
---
<span class:list={['logo', `logo--${variant}`]}>
  <svg class="logo__mark" width="26" height="26" viewBox="0 0 32 32" aria-hidden="true">
    <rect width="32" height="32" rx="8" fill="var(--c-primary)" />
    <g stroke="#ffffff" stroke-opacity="0.28" stroke-width="1.4">
      <line x1="12.5" y1="6" x2="12.5" y2="26" />
      <line x1="19.5" y1="6" x2="19.5" y2="26" />
    </g>
    <path d="M9 16.6l4.6 4.6L23 11.4" fill="none" stroke="#ffffff" stroke-width="3"
      stroke-linecap="round" stroke-linejoin="round" />
  </svg>
  <span class="logo__word">Planivo</span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .logo__mark { flex: none; }
  .logo__word {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: -0.02em;
    color: var(--c-primary-dark);
  }
  .logo--footer .logo__word { color: #fff; }
</style>
