---
// Layout base di ogni pagina: <head> con SEO, header, main, footer, barra CTA sticky mobile.
// Il tracking (Consent Mode + GTM + banner cookie) si aggancia in Fase 7, solo se PUBLIC_GTM_ID
// è impostata: qui è predisposto l'inserimento condizionale.
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';
import { organization } from '../lib/jsonld.js';

const {
  title,
  description,
  canonicalPath,
  ogImage,
  ogType,
  noindex = false,
  jsonLd,
  showStickyCta = true,
} = Astro.props;

const GTM_ID = import.meta.env.PUBLIC_GTM_ID;

// Organization è sitewide; le pagine aggiungono le proprie schede via la prop `jsonLd`.
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [organization(), ...pageJsonLd];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2f6f4f" />
    <meta name="facebook-domain-verification" content="djxvmoh5emezrzllangchv4nox7hki" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    {/* TODO_FONT: quando il woff2 subset è in /public/fonts/, decommenta (vedi README-TODO.md):
    <link rel="preload" href="/fonts/bricolage-grotesque.woff2" as="font" type="font/woff2" crossorigin /> */}

    <Seo
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={allJsonLd}
    />

    {/* === Consent Mode v2 (default DENIED) + GTM: SOLO se PUBLIC_GTM_ID è impostata (§7) === */}
    {
      GTM_ID && (
        <script is:inline define:vars={{ GTM_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          gtag('consent', 'default', {
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            analytics_storage: 'denied',
            wait_for_update: 500,
          });
          gtag('set', 'ads_data_redaction', true);
          (function (w, d, s, l, i) {
            w[l] = w[l] || [];
            w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
            var f = d.getElementsByTagName(s)[0],
              j = d.createElement(s),
              dl = l != 'dataLayer' ? '&l=' + l : '';
            j.async = true;
            j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
            f.parentNode.insertBefore(j, f);
          })(window, document, 'script', 'dataLayer', GTM_ID);
        </script>
      )
    }
  </head>
  <body>
    {
      GTM_ID && (
        <noscript
          set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`}
        />
      )
    }
    <a href="#main-content" class="skip-link">Salta al contenuto</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    {showStickyCta && <StickyCta />}

    {/* Attribuzione UTM + eventi dataLayer sempre attivi; banner/consenso solo con PUBLIC_GTM_ID. */}
    <script>
      import '../lib/analytics.js';
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    min-height: 100%;
  }
  body {
    display: flex;
    flex-direction: column;
  }
  main {
    flex: 1 0 auto;
  }
</style>
