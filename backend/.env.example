PORT=4000

# In locale (Postgres senza SSL):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/turni_app
DATABASE_SSL=false

# Su un provider hosted (Neon, Supabase, Railway, Vercel Postgres...) di solito serve:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_SSL=true

# Obbligatorio: usare una stringa lunga e casuale in produzione (es. `openssl rand -hex 32`).
# Il backend si RIFIUTA di avviarsi se manca; in produzione (NODE_ENV=production) si rifiuta anche
# se è ancora questo valore di esempio.
JWT_SECRET=change-me-to-a-long-random-string

# Ambiente: 'production' attiva i controlli di sicurezza più severi (es. rifiuto del JWT_SECRET di
# esempio) e disattiva gli script distruttivi (db:reset / seed:dirigente / db:restore) salvo
# ALLOW_DESTRUCTIVE=true.
# NODE_ENV=production
# Opt-in per forzare uno script distruttivo anche con NODE_ENV=production (usare con estrema cautela).
# ALLOW_DESTRUCTIVE=true

# --- Politica password (Fase S1) ---
# Requisiti di robustezza applicati a primo accesso, reset password e futuri reset via email.
# Modificabili senza toccare il codice. Il frontend li legge da GET /api/auth/password-policy.
# PASSWORD_MIN_LENGTH=8
# PASSWORD_REQUIRE_UPPERCASE=true
# PASSWORD_REQUIRE_LOWERCASE=true
# PASSWORD_REQUIRE_NUMBER=true
# PASSWORD_REQUIRE_SPECIAL=true
# Costo di hashing bcrypt (default 10). Alzarlo aumenta la sicurezza ma rallenta login/hash.
# BCRYPT_ROUNDS=10

# --- Protezione brute-force sul login (Fase S2) ---
# Dopo LOGIN_MAX_ATTEMPTS tentativi falliti consecutivi l'account è bloccato per
# LOGIN_LOCKOUT_MINUTES minuti (stato persistito su DB, compatibile con hosting serverless).
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15

# --- Token di autenticazione monouso (Fase S4, PREDISPOSIZIONE — nessun invio email attivo) ---
# Durata (minuti) dei token generati per verifica email / reset password / 2FA. Solo struttura:
# il servizio esiste ma non viene ancora usato da endpoint attivi.
# EMAIL_VERIFICATION_TTL_MINUTES=1440
# PASSWORD_RESET_TTL_MINUTES=30
# TWO_FACTOR_TTL_MINUTES=10

# --- Sistema email (Fase S5, PREDISPOSIZIONE) ---
# Provider di invio. Default 'noop': NON invia nulla, logga soltanto (nessun invio accidentale in
# sviluppo). Provider reali (es. smtp) saranno aggiunti in futuro insieme alle relative credenziali.
# EMAIL_PROVIDER=noop
# EMAIL_FROM=no-reply@tuodominio.it
# URL base del frontend, usato per costruire i link di verifica/reset nelle email.
# APP_BASE_URL=https://tuo-frontend.vercel.app
# (Futuri, quando si attiverà un provider SMTP reale — non usati ora)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# --- Cifratura dati sensibili at-rest (Fase S6, PREDISPOSIZIONE — non ancora applicata ai dati) ---
# Chiave AES-256-GCM in esadecimale (32 byte = 64 hex char). Generala con: openssl rand -hex 32
# Il modulo backend/src/utils/crypto.js esiste ma NON è ancora applicato ad alcun campo del DB:
# l'applicazione ai dati va fatta in una fase separata, su conferma esplicita.
# DATA_ENCRYPTION_KEY=
# ID della chiave primaria (default 'v1'), usato nel formato del valore cifrato per la rotazione.
# DATA_ENCRYPTION_KEY_ID=v1
# Chiavi ritirate (solo decifratura), per la rotazione. JSON id->hex, es: {"v0":"<hex 64 char>"}
# DATA_ENCRYPTION_KEYS_RETIRED=

# --- Demo Framework (Fase D1) ---
# Interruttore della modalità demo. Default: SPENTA. Con DEMO_MODE=true il frontend mostra il
# bottone "Prova la demo" e le rotte /api/demo/* diventano operative; le società demo vivono nello
# stesso DB (companies.is_demo=TRUE) e sono isolate dal multi-tenant come qualunque altra società.
# DEMO_MODE=true
# Giorni di vita di un ambiente demo prima del ri-caricamento lazy (ancora = oggi) al demo-login.
# DEMO_RESEED_AFTER_DAYS=7
# SOLO sviluppo: password assegnata agli utenti demo per il login manuale di ispezione. In
# produzione va lasciata vuota (password casuale mai comunicata, si entra solo dal demo-login).
# DEMO_PERSONA_PASSWORD=

# Credenziali del dirigente di bootstrap creato da `npm run seed:dirigente` (solo locale/dev: in
# produzione i dirigenti si creano dal pannello Super Admin, uno per società)
DIRIGENTE_USERNAME=dirigente2353
DIRIGENTE_PASSWORD=Filippo124
DIRIGENTE_EMAIL=dirigente@example.com
DIRIGENTE_COMPANY_NAME=Società Demo

# Credenziali dell'account super admin creato da `npm run seed:superadmin` (unico per l'intera
# piattaforma, non appartiene a nessuna società)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=CambiaMi1234
SUPERADMIN_EMAIL=superadmin@example.com

# Opzionale: restringe le richieste cross-origin all'URL del frontend deployato (SENZA slash finale,
# deve corrispondere esattamente all'header Origin del browser).
# Se non impostata, il backend accetta richieste da qualunque origine (va bene per iniziare).
# CORS_ORIGIN=https://tuo-frontend.vercel.app
